--// YARDIMCI GÖRSEL: Drop Shadow
local function CreateShadow(parent)
    local shadow = Instance.new("ImageLabel", parent)
    shadow.Name = "DropShadow"
    shadow.BackgroundTransparency = 1
    shadow.Position = UDim2.new(0, -15, 0, -15)
    shadow.Size = UDim2.new(1, 30, 1, 30)
    shadow.ZIndex = -1
    shadow.Image = "rbxassetid://1316045217"
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = 0.5
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(10, 10, 118, 118)
    return shadow
end

--// YARDIMCI FONKSİYON: GERÇEK GÖRÜNÜRLÜK
local function IsTrulyVisible(obj)
    local current = obj
    while current and current ~= game and current.Parent do
        if current:IsA("GuiObject") and not current.Visible then return false end
        current = current.Parent
    end
    return true
end

--// YARDIMCI FONKSİYON: KESKİN NİŞANCI TIKLAMA MOTORU
local function ForceClickUI(searchText)
    local found = false
    local insetY = GuiService:GetGuiInset().Y
    
    for _, desc in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and desc.Text ~= "" then
            if IsTrulyVisible(desc) and desc.AbsoluteSize.X > 0 and desc.AbsolutePosition.X > 0 then
                if string.find(string.lower(desc.Text), string.lower(searchText)) then
                    local btn = desc
                    while btn and not btn:IsA("GuiButton") and btn ~= LocalPlayer.PlayerGui do
                        btn = btn.Parent
                    end
                    
                    if btn and btn:IsA("GuiButton") then
                        pcall(function() for _, c in pairs(getconnections(btn.MouseButton1Click)) do c:Fire() end end)
                        local centerX = btn.AbsolutePosition.X + (btn.AbsoluteSize.X / 2)
                        local centerY = btn.AbsolutePosition.Y + (btn.AbsoluteSize.Y / 2) + insetY 
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
                        task.wait(0.05)
                        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
                        found = true
                        break
                    end
                end
            end
        end
    end
    return found
end

